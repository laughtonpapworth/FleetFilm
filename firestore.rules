rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return signedIn() && role() == 'admin'; }
    function isCommittee() { return signedIn() && role() in ['committee','admin']; }

    // User profiles
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId;
    }

    // Films
    match /films/{filmId} {
      allow read: if signedIn();
      allow create: if signedIn();

      // Updates
      allow update: if signedIn() && (
        isCommittee() ||
        // creator can edit basic fields while still in intake/basic
        (
          resource.data.createdBy == request.auth.uid &&
          resource.data.status in ['intake','review_basic'] &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'title','year','synopsis','ukDistributorName','availability','hasDisk',
            'runtimeMinutes','language','ukAgeRating','genre','country','posterUrl','imdbID'
          ])
        )
      );

      // Permanent delete (admin only)
      allow delete: if isAdmin();

      // Votes (per-user)
      match /votes/{userVote} {
        allow read: if signedIn();
        allow write: if signedIn() && request.auth.uid == userVote;
        allow delete: if isAdmin();
      }

      // Audit trail (append-only)
      match /audit/{auditId} {
        allow read: if signedIn();
        allow create: if signedIn();
        allow update, delete: if false;
      }
    }

    // Programme records
    match /programmes/{programmeId} {
      allow read: if signedIn();
      allow create, update, delete: if isCommittee();
    }

    // Viewing locations / addresses
    match /locations/{locId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

  }
}
